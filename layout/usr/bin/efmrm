#!/bin/bash

set -e

INSTALL_NAME="$1"

if [ -z "$INSTALL_NAME" ]; then
    echo "Error: No font install name specified."
    exit 1
fi

FONT_PATH="/Library/Themes/EmojiFontManager/$INSTALL_NAME.font"

if [ ! -d "$FONT_PATH" ]; then
    FONT_PATH="/var/jb/Library/Themes/EmojiFontManager/$INSTALL_NAME.font"
fi

if [ ! -d "$FONT_PATH" ] && command -v jbroot &> /dev/null; then
    FONT_PATH="$(jbroot)Library/Themes/EmojiFontManager/$INSTALL_NAME.font"
fi

if [ -d "$FONT_PATH" ]; then
    rm -rf "$FONT_PATH"
    echo "Font successfully removed."
else
    echo "Error: Font '$INSTALL_NAME' is not installed."
    exit 1
fi
